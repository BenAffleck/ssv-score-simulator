# ---------------------------------------------------------------------------
# REQUIRED — the two values you must fill in before running `npm run collect`.
# Copy this file to `.env` and fill them in. Never commit `.env`.
# ---------------------------------------------------------------------------

# Ethereum ARCHIVE node RPC. Must be an *archive* node: the collector reads
# balanceOf at historical block heights (one per day of the backfill window).
# A normal full node will fail with "missing trie node" / "state not available".
ARCHIVE_RPC_URL=

# HighSignal API key — auth for https://app.highsignal.xyz/api/users
HIGHSIGNAL_API_KEY=

# ---------------------------------------------------------------------------
# Optional overrides (sane mainnet defaults live in config.ts)
# ---------------------------------------------------------------------------
# SSV_ADDRESS=0x9D65fF81a3c488d585bBfb0Bfe3c7707c7917f54
# CSSV_ADDRESS=0xe018D31F120A637828F46aFD6c64EC099d960546
# SNAPSHOT_SPACE=mainnet.ssvnetwork.eth
# SNAPSHOT_API=https://hub.snapshot.org/graphql

# Backfill window, in days, for the balance time series (default 240).
# BACKFILL_DAYS=240

# Ethereum Communities delegation cohort: comma-separated HighSignal project
# slugs whose high-signal users' published eth addresses seed the cohort. Empty
# by default, in which case dataset.json carries an empty ethCommunities array.
# HIGHSIGNAL_ETH_PROJECTS=lido,ens
# Minimum HighSignal `signal` tier (low | mid | high) for a user to count toward
# that cohort — i.e. to receive delegated voting power. Only users at this tier
# or higher are included. Default `mid`.
# HIGHSIGNAL_ETH_MIN_SIGNAL=mid
# Other communities are PUBLIC — they are queried without any API key (the SSV
# admin HIGHSIGNAL_API_KEY only works for HIGHSIGNAL_PROJECT and 401s elsewhere).
# A project that fails is skipped with a warning, never fatal.
